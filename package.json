{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "implemetação do http:\\\\www.tabnews.com.br para htts://curso.dev",
  "main": "index.js",
  "scripts": {
    "dev": "npm run service:up && npm run wait-for-postgres && npm run migration:up && next dev",
    "service:up": "docker compose -f infra/compose.yaml up -d",
    "service:stop": "docker compose -f infra/compose.yaml stop",
    "service:down": "docker compose -f infra/compose.yaml down",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "test": "npm run service:up && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "test:watch": "jest --watchAll --runInBand",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "async-retry": "^1.3.3",
    "dotenv": "^16.4.4",
    "dotenv-expand": "^11.0.6",
    "next": "^16.1.1",
    "node-fetch": "^3.3.2",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.6.2",
    "prettier": "^3.6.2"
  }
}
